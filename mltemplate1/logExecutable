# ── Flask and web framework imports ──────────────────────────────────────────
from flask import Flask, jsonify, request, send_from_directory
# Flask               → creates the web application (the server itself)
# jsonify             → converts Python dict → JSON response to send back to UI
# request             → gives access to incoming HTTP request (body, params, headers)
# send_from_directory → serves static files (HTML, CSS, JS) from a folder

from flask_cors import CORS
# CORS → allows the UI (running on a different port/domain) to call this API
# without CORS, browsers block requests between different origins for security

import traceback
# traceback → captures the full error stack trace when an exception occurs
# useful for debugging — shows exactly which line caused the error

import os
# os → reads environment variables (like PORT) and builds file paths

import pandas as pd
# pandas → used for converting list of dicts → DataFrame and filtering rows

# ── Import ML logic from separate files ──────────────────────────────────────
from pipeline import process_data
# process_data() lives in pipeline.py — contains the full ML prediction logic
# imported here so app.py stays clean — only handles HTTP, not ML

from model_loader import load_metadata
# load_metadata() lives in model_loader.py — reads model_config_{market}.json
# imported here because multiple routes need to load metadata by market


# ── Create the Flask application ─────────────────────────────────────────────
app = Flask(__name__, static_folder="webapp", static_url_path="")
# Flask(__name__)     → creates the app, __name__ tells Flask which module it is
# static_folder       → folder where UI files (HTML, CSS, JS) are stored
# static_url_path=""  → serve static files from root URL "/" not "/static/"

CORS(app)
# enables CORS for ALL routes in this app
# without this, the React/HTML UI cannot call this API from a browser


# ─────────────────────────────────────────────────────────────────────────────
# Static file routes — serve the frontend UI
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/')
# registers this function to handle GET requests to root URL "/"
# when user visits the app URL, Flask calls root() and loads the UI
def root():
    # reads index.html from the webapp folder and sends it to the browser
    return send_from_directory(app.static_folder, 'index.html')


@app.route('/<path:filename>')
# <path:filename> → URL variable that captures everything after "/"
# e.g. "/static/main.js" → filename = "static/main.js"
# handles all static asset requests (CSS, JS, images) that the UI needs
def serve_static(filename):
    return send_from_directory(app.static_folder, filename)


# ─────────────────────────────────────────────────────────────────────────────
# Helper: _get_market_and_process_types(payload)
# Extracts market from payload, loads metadata from disk,
# and returns both market and process_types.
#
# process_types ALWAYS comes from metadata — never from the UI payload.
# This ensures process_types always matches what the model was trained with.
#
# Used by get_config(), get_account_mapping(), and process() routes
# because all three need market + process_types before doing anything.
#
# Returns: (market, process_types, error_response)
#   - if successful : (market, ["TRAVEL","MEALS",...], None)
#   - if failed     : (None,   None,                  jsonify error response)
# ─────────────────────────────────────────────────────────────────────────────

def _get_market_and_process_types(payload):
    # extract market from the UI payload
    # market is the only thing the UI needs to send — everything else
    # is derived from the metadata file on disk
    market = payload.get('market')

    # market is required — without it we cannot find the metadata file
    if not market:
        return None, None, (jsonify({"status": "error",
                                     "message": "'market' is required"}), 400)

    # load model_config_{market}.json from /mnt/models/ on disk
    # this file was produced by the trainer and copied here by SAP AI Core
    # returns a Python dict containing text_column, key_cols, process_types etc.
    try:
        metadata = load_metadata(market)
    except FileNotFoundError as e:
        # config file for this market does not exist on disk
        # means either training never ran or artifact was not registered
        return None, None, (jsonify({"status": "error", "message": str(e)}), 404)
    except Exception as e:
        return None, None, (jsonify({"status": "error", "message": str(e)}), 500)

    # extract process_types from metadata
    # set by trainer at training time — always a list e.g. ["TRAVEL", "MEALS"]
    # this is the ONLY source of process_types — never from UI payload
    process_types = metadata.get('process_types')

    # safety check — if process_types is missing in metadata,
    # the model was saved incorrectly and needs to be retrained
    if not process_types:
        return None, None, (jsonify({"status": "error",
                                     "message": f"'process_types' missing in metadata for market '{market}' — retrain the model!"}), 500)

    print(f"📋 market         : {market}")
    print(f"📋 process_types  : {process_types}")

    # return market, process_types, and None for error (None = no error)
    return market, process_types, None


# ─────────────────────────────────────────────────────────────────────────────
# Helper: _validate_primary_keys(records)
# Checks that every record contains all required primary key fields.
# Used by OverwritePrediction and OverwriteReview — both need the same check.
# Extracted into one helper to avoid repeating the same logic twice.
#
# Returns: list of missing key details — empty list means all keys present.
# ─────────────────────────────────────────────────────────────────────────────

def _validate_primary_keys(records):
    # these 7 fields uniquely identify one journal line row
    # same primary keys used in the original HDI JRNLOUTPUT table
    primary_keys = [
        "MTDPeriod", "DocumentNumber", "GLAccount",
        "PostingItem", "Ledger", "Entity/BU", "SourceDocumentNo"
    ]

    # loop over every record and every required key
    # if a key is missing in a record → add it to the missing list
    # result: [ {"index": 0, "missing_key": "Ledger"}, ... ] or [] if all present
    missing = [
        {"index": i, "missing_key": pk}
        for i, rec in enumerate(records)   # i = row number, rec = the dict
        for pk in primary_keys             # pk = each required key name
        if pk not in rec                   # only add if key is missing
    ]
    return missing


