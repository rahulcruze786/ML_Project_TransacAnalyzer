# ─────────────────────────────────────────────────────────────────────────────
# GET /v1/getMetadata?market=Hong+Kong
# Returns model_config_{market}.json contents as JSON.
# Reads from disk (/mnt/models/) — no UI data needed here.
# market is passed as a URL query parameter e.g. ?market=Hong Kong
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/getMetadata', methods=['GET'])
def get_metadata():
    try:
        # request.args → dict of URL query parameters (everything after ?)
        # .get('market') → safely returns None if ?market= is missing
        market = request.args.get('market')

        # market is required — without it we don't know which file to load
        if not market:
            return jsonify({"status": "error",
                            "message": "'market' param is required"}), 400

        # load_metadata() reads model_config_{market}.json from /mnt/models/
        # returns a Python dict — becomes JSON only when jsonify() is called
        metadata = load_metadata(market)

        # jsonify() converts Python dict → JSON HTTP response
        return jsonify({"status": "success", "data": metadata})

    except FileNotFoundError as e:
        # config file doesn't exist for this market on disk
        # 404 = resource not found
        return jsonify({"status": "error", "message": str(e)}), 404

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/getConfig
# Receives the full config table from UI.
# Loads process_types from metadata (not from UI).
# Filters config rows by market and process_types.
# Returns filtered rows as JSON.
#
# Previously read from HDI Configuration table — now UI sends the data.
#
# Expected request body (JSON):
# {
#   "market": "Hong Kong",      ← REQUIRED: used to load metadata + filter
#   "config": [                 ← REQUIRED: full config table rows from UI
#       { "Market": "Hong Kong", "ProcessType": "TRAVEL",
#         "Parameter": "THRESHOLD_AMOUNT", "Value": "50000" },
#       { "Market": "Hong Kong",
#         "Parameter": "OW_RL_FM_PROFIT_CENTRE", "Value": "1234" }
#   ]
# }
#
# process_types loaded from metadata — UI does NOT send processtype.
# ProcessType column may not exist in every config row — handled safely.
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/getConfig', methods=['POST'])
def get_config():
    try:
        # parse JSON request body → Python dict
        # silent=True → returns None if body is missing or invalid JSON
        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # ── Step 1: Get market and process_types from metadata ────────────────
        # process_types comes from metadata on disk — NOT from UI payload
        # _get_market_and_process_types() loads metadata and extracts process_types
        market, process_types, err = _get_market_and_process_types(payload)
        if err:
            # err is a (jsonify_response, status_code) tuple — return it directly
            return err

        # ── Step 2: Extract and validate config data ──────────────────────────
        # "config" is the full Configuration table rows sent from the UI
        # this was previously read from HDI Configuration table
        config_data = payload.get('config', [])
        if not config_data:
            return jsonify({"status": "error",
                            "message": "'config' list is required"}), 400

        # convert list of dicts → DataFrame for filtering
        config_df = pd.DataFrame(config_data)

        # ── Step 3: Filter by market ──────────────────────────────────────────
        # Market column is always expected in config data
        if 'Market' not in config_df.columns:
            return jsonify({"status": "error",
                            "message": "'Market' column missing in config data"}), 400

        # keep only rows where Market matches
        config_df = config_df[config_df['Market'] == market]
        print(f"📋 rows after market filter    : {len(config_df)}")

        # ── Step 4: Filter by process_types from metadata ────────────────────
        # process_types is a list from metadata e.g. ["TRAVEL", "MEALS"]
        # some config rows may not have ProcessType (global params) — keep those
        # .isin() keeps rows where ProcessType matches ANY value in the list
        if 'ProcessType' in config_df.columns:
            config_df = config_df[
                config_df['ProcessType'].isin(process_types) |  # matches process_types
                config_df['ProcessType'].isna()                  # OR has no ProcessType (global rows)
            ]
            print(f"📋 rows after processtype filter: {len(config_df)}")
        else:
            # ProcessType column doesn't exist in config data
            # skip filter — return all market-filtered rows
            print(f"⚠️ 'ProcessType' column not found — skipping processtype filter")

        # to_dict(orient='records') → DataFrame → list of dicts
        # one dict per row — natural format for UI table display
        return jsonify({"status": "success",
                        "data": config_df.to_dict(orient='records')})

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


