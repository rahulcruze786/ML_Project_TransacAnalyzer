# ─────────────────────────────────────────────────────────────────────────────
# POST /saveAccountMapping
# Accepts updated account mapping records from the UI.
# Validates required fields are present, then returns the records.
# Previously wrote to HDI Accountaxcode table — now returns JSON to UI only.
#
# Expected request body (JSON):
# {
#   "payload": [
#       { "Account": "12345", "ExpenseType": "TRAVEL",
#         "ProcessType": "TRAVEL", "Market": "Hong Kong" },
#       ...
#   ]
# }
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/saveAccountMapping', methods=['POST'])
def save_account_mapping():
    try:
        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # extract the "payload" key from the request body
        # this is a list of account mapping records to save
        # default [] means no crash if "payload" key is missing
        records = payload.get('payload', [])
        if not records:
            return jsonify({"status": "error", "message": "No records in 'payload'"}), 400

        # these 4 fields are required in every account mapping record
        required = ["Account", "ExpenseType", "ProcessType", "Market"]

        # same pattern as _validate_primary_keys but inline here
        # builds a list of missing field details across all records
        missing = [
            {"index": i, "missing_key": k}
            for i, rec in enumerate(records)   # loop over each record
            for k in required                  # loop over each required field
            if k not in rec                    # only if field is missing
        ]
        if missing:
            return jsonify({
                "status":  "error",
                "message": "Missing required field(s)",
                "details": missing
            }), 400

        # return accepted records back to UI
        return jsonify({
            "status":  "success",
            "message": f"Updated {len(records)} record(s).",
            "data":    records
        })

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


# ─────────────────────────────────────────────────────────────────────────────
# App entry point
# Only runs when this file is executed directly: python app.py
# NOT executed when SAP AI Core imports this file via gunicorn/uwsgi
# ─────────────────────────────────────────────────────────────────────────────

if __name__ == '__main__':
    # read PORT from environment variable — SAP AI Core injects this at runtime
    # if not set (e.g. running locally) default to port 8080
    # int() converts the string env variable → integer that app.run() expects
    port = int(os.environ.get('PORT', 8080))

    # start the Flask development server
    # host='0.0.0.0' → listen on all network interfaces (required for Docker)
    #                   '127.0.0.1' would only accept connections from localhost
    # port=port       → the port number read above
    app.run(host='0.0.0.0', port=port)
