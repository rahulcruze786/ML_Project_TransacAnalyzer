@app.route('/v1/process', methods=['POST'])
def process():
    try:
        # parse JSON request body → Python dict
        # silent=True → returns None instead of raising error if body is invalid
        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error",
                            "message": "Missing JSON body"}), 400

        # ── Step 1: Validate market ───────────────────────────────────────────
        # market is the only identification the UI sends
        # all filtering and data processing happens in pipeline.py
        market = payload.get('market')
        if not market:
            return jsonify({"status": "error",
                            "message": "'market' is required"}), 400

        # ── Step 2: Validate all required data keys are present ───────────────
        # just check the keys exist — no filtering or conversion here
        # pipeline.py is responsible for all data filtering and processing
        if not payload.get('journal_lines'):
            return jsonify({"status": "error",
                            "message": "'journal_lines' is required"}), 400

        if not payload.get('account_mapping'):
            return jsonify({"status": "error",
                            "message": "'account_mapping' is required"}), 400

        if not payload.get('config'):
            return jsonify({"status": "error",
                            "message": "'config' is required"}), 400

        # ── Step 3: Pass raw payload directly to pipeline ────────────────────
        # app.py does NO filtering, NO conversion, NO data manipulation
        # process_data() in pipeline.py receives the full raw payload
        # and handles everything — filtering by market + process_types,
        # converting config rows → config_params dict, and running prediction
        result = process_data(payload)

        # jsonify() converts result dict → JSON HTTP response
        return jsonify(result)

    except Exception as e:
        # traceback.format_exc() → full stack trace as a readable string
        return jsonify({
            "status":    "error",
            "message":   str(e),
            "traceback": traceback.format_exc()
        }), 500
