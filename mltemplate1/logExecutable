# ── Flask and web framework imports ──────────────────────────────────────────
from flask import Flask, jsonify, request, send_from_directory
# Flask          → creates the web application (the server itself)
# jsonify        → converts Python dict → JSON response to send back to UI
# request        → gives access to incoming HTTP request (body, params, headers)
# send_from_directory → serves static files (HTML, CSS, JS) from a folder

from flask_cors import CORS
# CORS → allows the UI (running on a different port/domain) to call this API
# without CORS, browsers block requests between different origins for security

import traceback
# traceback → captures the full error stack trace when an exception occurs
# useful for debugging — shows exactly which line caused the error

import os
# os → reads environment variables (like PORT) and builds file paths

# ── Import ML logic from separate files ──────────────────────────────────────
from pipeline import process_data
# process_data() lives in pipeline.py — contains the full ML prediction logic
# imported here so app.py stays clean — only handles HTTP, not ML

from model_loader import load_metadata
# load_metadata() lives in model_loader.py — reads model_config_{market}.json
# imported here for the /v1/getMetadata route only

# ── Create the Flask application ─────────────────────────────────────────────
app = Flask(__name__, static_folder="webapp", static_url_path="")
# Flask(__name__)     → creates the app, __name__ tells Flask which module it is
# static_folder       → folder name where UI files (HTML, CSS, JS) are stored
# static_url_path=""  → serve static files from root URL "/" not "/static/"

CORS(app)
# enables CORS for ALL routes in this app
# without this, the React/HTML UI cannot call the API from a browser


# ─────────────────────────────────────────────────────────────────────────────
# Static file routes — serve the frontend UI
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/')
# @app.route('/') → registers this function to handle GET requests to "/"
# when user visits the root URL, Flask calls root() below
def root():
    # send_from_directory → reads index.html from the webapp folder and sends it
    # this loads the React/HTML frontend in the browser
    return send_from_directory(app.static_folder, 'index.html')


@app.route('/<path:filename>')
# <path:filename> → a URL variable that captures everything after "/"
# e.g. "/static/main.js" → filename = "static/main.js"
# handles all static asset requests (CSS, JS, images) that the UI needs
def serve_static(filename):
    # serves the requested file from the webapp folder
    return send_from_directory(app.static_folder, filename)


# ─────────────────────────────────────────────────────────────────────────────
# GET /v1/health
# Simple liveness check — used by SAP AI Core / load balancer to confirm
# the container is running and healthy. Returns immediately with no logic.
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/health')
def health():
    # jsonify() converts the Python dict → JSON string
    # Flask automatically sets Content-Type: application/json in the response
    return jsonify({"status": "healthyUI"})


# ─────────────────────────────────────────────────────────────────────────────
# GET /v1/getMetadata?market=Hong+Kong
# Returns the model_config_{market}.json file contents as JSON.
# Still reads from disk (/mnt/models/) — no UI data needed here.
# market is passed as a URL query parameter e.g. ?market=Hong Kong
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/getMetadata', methods=['GET'])
def get_metadata():
    try:
        # request.args → dict of URL query parameters (everything after ?)
        # .get('market') → safely returns None if ?market= is not in the URL
        market = request.args.get('market')

        # if market is missing, return 400 Bad Request immediately
        # 400 means "the client sent a bad/incomplete request"
        if not market:
            return jsonify({"status": "error", "message": "'market' param is required"}), 400

        # load_metadata() reads model_config_{market}.json from /mnt/models/
        # returns a Python dict — NOT JSON yet at this point
        metadata = load_metadata(market)

        # jsonify() converts the Python dict → JSON response
        # 200 OK is the default status code (no need to specify)
        return jsonify({"status": "success", "data": metadata})

    except FileNotFoundError as e:
        # raised by load_metadata() if the config file doesn't exist for this market
        # 404 = "resource not found" — correct status for a missing file
        return jsonify({"status": "error", "message": str(e)}), 404

    except Exception as e:
        # catches any other unexpected error
        # str(e) converts the exception object → readable error message string
        # 500 = "internal server error"
        return jsonify({"status": "error", "message": str(e)}), 500


# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/getConfig
# Receives config data from the UI, filters it by market and processtype,
# and returns the filtered rows as JSON.
# Previously read from HDI Configuration table — now UI sends the data.
#
# Expected request body (JSON):
# {
#   "market":      "Hong Kong",         ← optional filter
#   "processtype": "TRAVEL",            ← optional filter
#   "config": [                         ← required: list of config rows
#       { "Market": "Hong Kong", "ProcessType": "TRAVEL",
#         "Parameter": "THRESHOLD_AMOUNT", "Value": "50000" },
#       ...
#   ]
# }
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/getConfig', methods=['POST'])
def get_config():
    try:
        # pandas is imported here (inside the function) rather than at the top
        # because only this route needs it — keeps top-level imports clean
        import pandas as pd

        # request.get_json(silent=True) → parses the JSON request body
        # into a Python dict. silent=True means if the body is missing
        # or invalid JSON, it returns None instead of raising an exception
        payload = request.get_json(silent=True)

        # if payload is None (missing or broken JSON body) → return 400 error
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # extract optional filter values from the payload dict
        # .get() safely returns None if the key doesn't exist — no KeyError
        market       = payload.get('market')       # e.g. "Hong Kong" or None
        process_type = payload.get('processtype')  # e.g. "TRAVEL" or None

        # extract the config data list — default to [] if key is missing
        config_data = payload.get('config', [])

        # if no config data was sent, return 400 — nothing to filter
        if not config_data:
            return jsonify({"status": "error", "message": "'config' list is required"}), 400

        # convert list of dicts → pandas DataFrame for filtering
        # e.g. [{"Market":"HK","Parameter":"X","Value":"50000"}] → DataFrame
        config_df = pd.DataFrame(config_data)

        # filter by market only if:
        # 1. market was provided in the request (not None)
        # 2. the DataFrame actually has a "Market" column
        # config_df['Market'] == market → creates a True/False column per row
        # config_df[...] keeps only the True rows
        if market and 'Market' in config_df.columns:
            config_df = config_df[config_df['Market'] == market]

        # filter by process_type only if:
        # 1. processtype was provided in the request
        # 2. the DataFrame actually has a "ProcessType" column
        # applied on already-market-filtered DataFrame → cumulative AND filter
        if process_type and 'ProcessType' in config_df.columns:
            config_df = config_df[config_df['ProcessType'] == process_type]

        # to_dict(orient='records') → converts filtered DataFrame back to
        # list of dicts: [{"Market":"HK","Parameter":"X","Value":"50000"}, ...]
        # jsonify() wraps it in a JSON response
        return jsonify({"status": "success", "data": config_df.to_dict(orient='records')})

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/getAccountMapping
# Receives account mapping data from UI, filters by market and processtype,
# returns filtered rows as JSON.
# Previously read from HDI Accountaxcode table — now UI sends the data.
#
# Expected request body (JSON):
# {
#   "market":          "Hong Kong",      ← optional filter
#   "processtype":     "TRAVEL,MEALS",   ← optional filter, comma-separated
#   "account_mapping": [                 ← required: list of mapping rows
#       { "Account": "12345", "ExpenseType": "TRAVEL",
#         "ProcessType": "TRAVEL", "Market": "Hong Kong" },
#       ...
#   ]
# }
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/getAccountMapping', methods=['POST'])
def get_account_mapping():
    try:
        import pandas as pd

        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        market           = payload.get('market')
        process_type     = payload.get('processtype')
        account_map_data = payload.get('account_mapping', [])

        if not account_map_data:
            return jsonify({"status": "error", "message": "'account_mapping' list is required"}), 400

        # convert list of account mapping dicts → DataFrame for filtering
        mapping_df = pd.DataFrame(account_map_data)

        # filter by market if provided and column exists
        if market and 'Market' in mapping_df.columns:
            mapping_df = mapping_df[mapping_df['Market'] == market]

        # process_type can be comma-separated e.g. "TRAVEL,MEALS"
        # split(",") → ["TRAVEL", "MEALS"]
        # .strip() removes any accidental spaces around each value
        # .isin([...]) keeps rows where ProcessType matches ANY value in the list
        if process_type and 'ProcessType' in mapping_df.columns:
            pts        = [pt.strip() for pt in process_type.split(',')]
            mapping_df = mapping_df[mapping_df['ProcessType'].isin(pts)]

        return jsonify({"status": "success", "data": mapping_df.to_dict(orient='records')})

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/process
# Main prediction pipeline trigger.
# UI sends all data (journal lines, account mapping, config params).
# Calls process_data() in pipeline.py and returns prediction results as JSON.
#
# Expected request body (JSON):
# {
#   "market":          "Hong Kong",
#   "journal_lines":   [ { ...one row per journal entry... } ],
#   "account_mapping": [ { "Account": "12345", "ExpenseType": "TRAVEL", ... } ],
#   "config_params":   { "THRESHOLD_AMOUNT": "50000", ... }
# }
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/process', methods=['POST'])
def process():
    try:
        payload = request.get_json(silent=True)

        # if request body is missing or not valid JSON → return 400
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # pass the entire payload dict directly to process_data() in pipeline.py
        # process_data() handles all ML logic — this route only handles HTTP
        # result is already a dict: { status, message, rows_processed, data }
        result = process_data(payload)

        # jsonify() converts the result dict → JSON HTTP response
        return jsonify(result)

    except Exception as e:
        # traceback.format_exc() → full stack trace as a string
        # included in the error response so developers can debug easily
        return jsonify({
            "status":    "error",
            "message":   str(e),
            "traceback": traceback.format_exc()
        }), 500


# ─────────────────────────────────────────────────────────────────────────────
# Helper: _validate_primary_keys(records)
# Checks that every record in a list contains all required primary key fields.
# Used by OverwritePrediction and OverwriteReview — both need the same check.
# Extracted into one function to avoid repeating the same logic twice.
#
# Returns a list of missing key details — empty list means all keys present.
# ─────────────────────────────────────────────────────────────────────────────

def _validate_primary_keys(records):
    # these 7 fields uniquely identify one journal line row
    # same primary keys used in the original HDI JRNLOUTPUT table
    primary_keys = [
        "MTDPeriod", "DocumentNumber", "GLAccount",
        "PostingItem", "Ledger", "Entity/BU", "SourceDocumentNo"
    ]

    # list comprehension that builds a list of missing key details
    # loops over every record (i = index, rec = the dict)
    # for each record, loops over every required primary key
    # if the key is NOT in the record dict → add it to missing list
    # result: [ {"index": 0, "missing_key": "Ledger"}, ... ] or [] if all present
    missing = [
        {"index": i, "missing_key": pk}
        for i, rec in enumerate(records)   # i=0,1,2...  rec={...dict...}
        for pk in primary_keys             # pk="MTDPeriod", "DocumentNumber"...
        if pk not in rec                   # only include if key is missing
    ]
    return missing


# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/OverwritePrediction
# Accepts reviewer-corrected prediction records from the UI.
# Validates that all primary keys are present, then returns the records.
# Previously wrote to HDI JRNLOUTPUT table — now returns JSON to UI only.
#
# Expected body: a single record dict OR a list of record dicts
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/OverwritePrediction', methods=['POST'])
def upsert_jrnoutput():
    try:
        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # allow UI to send either a single dict or a list of dicts
        # isinstance(payload, list) → True if payload is already a list
        # if it's a single dict, wrap it in a list so the rest of the code
        # always works with a list — consistent handling either way
        records = payload if isinstance(payload, list) else [payload]

        # validate all primary keys are present in every record
        # _validate_primary_keys() returns [] if all good, or list of missing keys
        missing = _validate_primary_keys(records)
        if missing:
            # 400 Bad Request — client sent incomplete data
            return jsonify({
                "status":  "error",
                "message": "Missing primary key(s)",
                "details": missing   # tells the UI exactly which keys are missing
            }), 400

        # return accepted records back to UI
        # f-string: f"{len(records)}" → inserts the count of records into the string
        return jsonify({
            "status":  "success",
            "message": f"{len(records)} record(s) accepted.",
            "data":    records
        })

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


