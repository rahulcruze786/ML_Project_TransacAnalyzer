# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/process
# Main prediction pipeline trigger.
# UI sends market, journal lines, account mapping, and config table rows.
# process_types loaded from metadata — UI does NOT send processtype.
# Server converts config rows → flat config_params dict internally.
# Calls process_data() in pipeline.py and returns prediction results.
#
# Expected request body (JSON):
# {
#   "market":          "Hong Kong",   ← REQUIRED: string
#   "journal_lines":   [ {...} ],     ← REQUIRED: journal line rows
#   "account_mapping": [ {...} ],     ← REQUIRED: account mapping rows
#   "config": [                       ← REQUIRED: config table rows
#       { "Market": "Hong Kong", "ProcessType": "TRAVEL",
#         "Parameter": "THRESHOLD_AMOUNT", "Value": "50000" },
#       ...
#   ]
# }
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/process', methods=['POST'])
def process():
    try:
        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # ── Step 1: Get market and process_types from metadata ────────────────
        # process_types comes from metadata — NOT from UI payload
        # this is the same process_types the model was trained with
        market, process_types, err = _get_market_and_process_types(payload)
        if err:
            return err

        # ── Step 2: Validate all required data keys are present ───────────────
        if not payload.get('journal_lines'):
            return jsonify({"status": "error",
                            "message": "'journal_lines' is required"}), 400
        if not payload.get('account_mapping'):
            return jsonify({"status": "error",
                            "message": "'account_mapping' is required"}), 400
        if not payload.get('config'):
            return jsonify({"status": "error",
                            "message": "'config' is required"}), 400

        # ── Step 3: Convert config rows → flat config_params dict ─────────────
        # UI sends config as table rows (list of dicts):
        # [{"Market":"HK","ProcessType":"TRAVEL","Parameter":"THRESHOLD_AMOUNT","Value":"50000"}]
        #
        # process_data() in pipeline.py needs a flat key-value dict:
        # { "THRESHOLD_AMOUNT": "50000" }
        #
        # server does this conversion using process_types from metadata
        # UI stays simple — only sends raw table rows
        config_rows = payload.get('config', [])
        config_df   = pd.DataFrame(config_rows)

        # filter config by market
        if 'Market' in config_df.columns:
            config_df = config_df[config_df['Market'] == market]

        # filter config by process_types from metadata
        # keep matching rows AND global rows (no ProcessType value)
        # global rows are config params that apply to all process types
        if 'ProcessType' in config_df.columns:
            config_df = config_df[
                config_df['ProcessType'].isin(process_types) |  # matches process_types
                config_df['ProcessType'].isna()                  # OR global rows
            ]

        # validate Parameter and Value columns exist before converting
        if 'Parameter' not in config_df.columns or 'Value' not in config_df.columns:
            return jsonify({"status": "error",
                            "message": "config rows must have 'Parameter' and 'Value' columns"}), 400

        # zip() pairs Parameter and Value columns together
        # dict() converts those pairs → flat key-value dict
        # e.g. Parameter=["THRESHOLD_AMOUNT"], Value=["50000"]
        #   → { "THRESHOLD_AMOUNT": "50000" }
        config_params = dict(zip(config_df['Parameter'], config_df['Value']))
        print(f"📋 config_params built: {list(config_params.keys())}")

        # ── Step 4: Build internal payload for process_data() ─────────────────
        # process_data() in pipeline.py expects this exact structure
        # rebuilt cleanly here so pipeline.py never needs to know
        # about the raw UI payload format
        internal_payload = {
            "market":          market,
            "journal_lines":   payload.get('journal_lines'),
            "account_mapping": payload.get('account_mapping'),
            "config_params":   config_params
        }

        print(f"📋 journal_lines  : {len(internal_payload['journal_lines'])} rows")
        print(f"📋 account_mapping: {len(internal_payload['account_mapping'])} rows")

        # ── Step 5: Call pipeline and return result ───────────────────────────
        # process_data() runs the full ML pipeline and returns:
        # { status, message, rows_processed, execution_time_seconds, data }
        result = process_data(internal_payload)

        # jsonify() converts result dict → JSON HTTP response
        return jsonify(result)

    except Exception as e:
        # traceback.format_exc() → full stack trace as readable string
        # helps developers debug exactly which line caused the error
        return jsonify({
            "status":    "error",
            "message":   str(e),
            "traceback": traceback.format_exc()
        }), 500


# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/OverwritePrediction
# Accepts reviewer-corrected prediction records from the UI.
# Validates all primary keys are present, returns accepted records as JSON.
# Previously wrote to HDI JRNLOUTPUT table — now returns JSON to UI only.
#
# Expected body: a single record dict OR a list of record dicts
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/OverwritePrediction', methods=['POST'])
def upsert_jrnoutput():
    try:
        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # allow UI to send either a single dict or a list of dicts
        # if it is a single dict → wrap in [] so code always works with a list
        records = payload if isinstance(payload, list) else [payload]

        # validate all 7 primary keys are present in every record
        # returns [] if all good, list of missing details if not
        missing = _validate_primary_keys(records)
        if missing:
            return jsonify({
                "status":  "error",
                "message": "Missing primary key(s)",
                "details": missing
            }), 400

        # return accepted records back to UI
        return jsonify({
            "status":  "success",
            "message": f"{len(records)} record(s) accepted.",
            "data":    records
        })

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


