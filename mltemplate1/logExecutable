# ─────────────────────────────────────────────────────────────────────────────
# GET /v1/getMetadata?market=Hong+Kong
# Returns model_config_{market}.json contents as JSON.
# Still reads from disk (/mnt/models/) — no UI data needed here.
# market is passed as a URL query parameter e.g. ?market=Hong Kong
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/getMetadata', methods=['GET'])
def get_metadata():
    try:
        # request.args → dict of URL query parameters (everything after ?)
        # .get('market') → safely returns None if ?market= is not in the URL
        market = request.args.get('market')

        # market is required — without it we don't know which config file to load
        if not market:
            return jsonify({"status": "error", "message": "'market' param is required"}), 400

        # load_metadata() reads model_config_{market}.json from /mnt/models/
        # returns a Python dict — becomes JSON only when jsonify() is called
        metadata = load_metadata(market)

        return jsonify({"status": "success", "data": metadata})

    except FileNotFoundError as e:
        # raised by load_metadata() if config file doesn't exist for this market
        # 404 = resource not found
        return jsonify({"status": "error", "message": str(e)}), 404

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


# ─────────────────────────────────────────────────────────────────────────────
# POST /v1/getConfig
# Receives the full config table from UI, filters by market and processtype,
# returns filtered rows as JSON.
# Previously read from HDI Configuration table — now UI sends the data.
#
# Expected request body (JSON):
# {
#   "market":      "Hong Kong",              ← REQUIRED: string
#   "processtype": ["TRAVEL", "MEALS"],      ← REQUIRED: list (UI always sends list)
#   "config": [                              ← REQUIRED: config table rows
#       { "Market": "Hong Kong", "ProcessType": "TRAVEL",
#         "Parameter": "THRESHOLD_AMOUNT", "Value": "50000" },
#       { "Market": "Hong Kong",
#         "Parameter": "OW_RL_FM_PROFIT_CENTRE", "Value": "1234" }
#   ]
# }
#
# Note: ProcessType column may not exist in every config row — handled safely.
# ─────────────────────────────────────────────────────────────────────────────

@app.route('/v1/getConfig', methods=['POST'])
def get_config():
    try:
        # request.get_json(silent=True) → parses JSON body → Python dict
        # silent=True → returns None instead of raising error if body is invalid
        payload = request.get_json(silent=True)
        if not payload:
            return jsonify({"status": "error", "message": "Missing JSON body"}), 400

        # ── Step 1: Extract and validate market ───────────────────────────────
        market = payload.get('market')
        if not market:
            return jsonify({"status": "error", "message": "'market' is required"}), 400

        # ── Step 2: Extract and validate processtype ──────────────────────────
        # UI always sends processtype as a list e.g. ["TRAVEL", "MEALS"]
        # no conversion needed — just validate it is a non-empty list
        process_type = payload.get('processtype')
        if not isinstance(process_type, list) or not process_type:
            return jsonify({"status": "error",
                            "message": "'processtype' must be a non-empty list e.g. ['TRAVEL','MEALS']"}), 400

        print(f"📋 market        : {market}")
        print(f"📋 process_types : {process_type}")

        # ── Step 3: Extract and validate config data ──────────────────────────
        # "config" is the full Configuration table rows sent from the UI
        config_data = payload.get('config', [])
        if not config_data:
            return jsonify({"status": "error", "message": "'config' list is required"}), 400

        # convert list of dicts → DataFrame for easy filtering
        config_df = pd.DataFrame(config_data)

        # ── Step 4: Filter by market — always required ────────────────────────
        if 'Market' not in config_df.columns:
            return jsonify({"status": "error",
                            "message": "'Market' column missing in config data"}), 400

        # keep only rows where Market matches the requested market
        config_df = config_df[config_df['Market'] == market]
        print(f"📋 rows after market filter    : {len(config_df)}")

        # ── Step 5: Filter by processtype — column might NOT exist ────────────
        # some config rows may not have ProcessType (global params for all types)
        # only filter if the column exists — otherwise return all market rows
        if 'ProcessType' in config_df.columns:
            # .isin(process_type) → keeps rows where ProcessType matches
            # ANY value in the list
            # e.g. ["TRAVEL","MEALS"] keeps rows where ProcessType is TRAVEL OR MEALS
            config_df = config_df[config_df['ProcessType'].isin(process_type)]
            print(f"📋 rows after processtype filter: {len(config_df)}")
        else:
            print(f"⚠️ 'ProcessType' column not found — skipping processtype filter")

        # to_dict(orient='records') → DataFrame → list of dicts
        # one dict per row — natural format for UI to consume
        return jsonify({"status": "success", "data": config_df.to_dict(orient='records')})

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500


