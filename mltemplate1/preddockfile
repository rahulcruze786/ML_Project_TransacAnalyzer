FROM python:3.11.14-slim
WORKDIR /app
COPY shared/ ./shared/
COPY prediction/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY prediction/app.py .          # copies to /app/app.py ✅
RUN mkdir -p models
ENV PYTHONPATH=/app
EXPOSE 8080
CMD ["python", "app.py"]          # ← FIXED: matches where file actually is ✅
